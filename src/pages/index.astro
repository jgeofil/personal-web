---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.jpg';
import Layout from '../layouts/Layout.astro';
import SocialGrid from '../components/SocialGrid.astro';
import Card from '../components/Card.astro';
import cvData from '../data/cv.json';
export const prerender = true;
---

<Layout title="Jeremy Georges-Filteau - About me" description='Explore the personal website of Jeremy Georges-Filteau, a Machine Learning Engineer and Computational Biologist specializing in GANs and healthcare data.'>
	<main>
		<div>
			<!-- Optimize: Use Astro's Image component with local assets. This allows Astro to automatically optimize the image (resizing, converting to WebP/AVIF, etc.) during the build process, reducing the final bundle size, improving LCP and page load times. Explicit width and height prevent Cumulative Layout Shift (CLS). -->
			<Image class="profile-img" src={profileImage} alt="Jeremy Georges-Filteau" width="200" height="200" loading="eager" />
			
			
			<div class="about">
				<h1>About me</h1>
				<p>
					I'm Jeremy Georges-Filteau, a Machine Learning Engineer and Computational Biologist from Québec city, Canada.
				</p>
			</div>
		</div>
		
		
		<ul role="list" class="link-card-grid">
			<Card
				href="/cv"
				title="CV"
				body="You can find my CV here."
			/>
		</ul>
		<SocialGrid items={cvData.links}/>
	</main>
</Layout>

<style>
	body {
		margin: auto;
		padding: 1em;
		max-width: 60ch;
	}

	.profile-img {
		border-radius: 50%;
		float: left;
		margin-right: 25px;
	}

	.about {
		margin-left: 25px;
	}

	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(24ch, 1fr));
		gap: 1rem;
		padding: 50px 0 0 0;
	}
</style>
